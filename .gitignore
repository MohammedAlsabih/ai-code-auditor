# virtualenvs / caches / build output
.venv/
.venv311/
.venv-check/
.venv-*/
__pycache__/
*.egg-info/
dist/
build/
.pytest_cache/
.cache/

# scan OUTPUT is never committed: real reports may contain source snippets.
# `*-report/` covers any <name>-report/ output directory; `*-report-*/`
# covers suffixed round outputs (<name>-report-<round>/, ...).
# examples/ (curated fixture output) and src/auditor/web/static/ (the shipped
# SPA build) stay TRACKED.
*-report/
*-report-*/
trial-*/
field-*/

# local review sidecars: private reviewer decisions, never published
*.reviews.json
# W3-B/C/D/E AI sidecars (advisory results, consent audit, batch metadata,
# independent audit results) — local-only, never published
*.ai-reviews.json
*.ai-consent.json
*.ai-batches.json
*.ai-audit.json

# W1 web UI build artifacts.
# NOTE: src/auditor/web/static/ is intentionally NOT ignored — the built SPA is
# committed so the wheel and a clean checkout work with no Node. Only
# node_modules and TypeScript scratch files are ignored.
web/node_modules/
web/*.tsbuildinfo
docs/superpowers/

# W2-B2.8D quality baseline: sampler, source-context dumps, and detailed
# per-finding labels are LOCAL ONLY (paths/snippets). Only the anonymized
# docs/quality/baseline-summary.json is committed.
.quality-local/
